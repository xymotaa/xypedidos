@model ListasCompras.Models.EstoqueIndexViewModel
@{
    Layout = null;
    ViewData["Title"] = "Estoque";

    var nomeLoja = ViewData["NomeLoja"] as string ?? "Minha Loja";
    var logo = ViewData["LogoLoja"] as string;
    var inicial = string.IsNullOrWhiteSpace(nomeLoja) ? "L" : nomeLoja.Trim()[0].ToString().ToUpper();
}
<!DOCTYPE html>
<html class="light" lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@nomeLoja — @ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-tertiary-container": "#93baa7", "outline-variant": "#bfc9c3",
                        "on-tertiary-fixed-variant": "#294e3f", "surface": "#f8f9ff",
                        "inverse-on-surface": "#eaf1ff", "outline": "#707974", "on-primary": "#ffffff",
                        "secondary": "#006c49", "error-container": "#ffdad6", "primary-fixed-dim": "#95d3ba",
                        "on-secondary": "#ffffff", "inverse-primary": "#95d3ba", "primary": "#003527",
                        "on-error-container": "#93000a", "on-tertiary-fixed": "#002115", "primary-fixed": "#b0f0d6",
                        "on-surface": "#0b1c30", "tertiary-fixed": "#c3ecd7", "on-primary-container": "#80bea6",
                        "surface-container-highest": "#d3e4fe", "on-primary-fixed-variant": "#0b513d",
                        "on-error": "#ffffff", "surface-container-lowest": "#ffffff", "surface-container": "#e5eeff",
                        "secondary-fixed": "#6ffbbe", "surface-container-low": "#eff4ff", "surface-tint": "#2b6954",
                        "background": "#f8f9ff", "on-primary-fixed": "#002117", "primary-container": "#064e3b",
                        "on-background": "#0b1c30", "tertiary-container": "#274b3c", "error": "#ba1a1a",
                        "surface-bright": "#f8f9ff", "inverse-surface": "#213145", "tertiary": "#0e3427",
                        "surface-dim": "#cbdbf5", "on-secondary-fixed-variant": "#005236", "tertiary-fixed-dim": "#a8cfbc",
                        "secondary-fixed-dim": "#4edea3", "surface-container-high": "#dce9ff",
                        "on-secondary-container": "#00714d", "secondary-container": "#6cf8bb",
                        "surface-variant": "#d3e4fe", "on-surface-variant": "#404944", "on-tertiary": "#ffffff",
                        "on-secondary-fixed": "#002113",
                        "warning": "#8a5300", "warning-container": "#ffddb1"
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                    spacing: { "container-margin": "24px", "lg": "24px", "base": "4px", "gutter": "16px", "sm": "8px", "xs": "4px", "md": "16px", "xl": "32px" },
                    fontFamily: {
                        "body-md": ["Hanken Grotesk"], "headline-md": ["Hanken Grotesk"], "title-lg": ["Hanken Grotesk"],
                        "body-lg": ["Hanken Grotesk"], "label-sm": ["Hanken Grotesk"], "headline-lg": ["Hanken Grotesk"],
                        "display-lg": ["Hanken Grotesk"], "label-md": ["Hanken Grotesk"]
                    },
                    fontSize: {
                        "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "headline-md": ["22px", { "lineHeight": "30px", "fontWeight": "600" }],
                        "title-lg": ["18px", { "lineHeight": "24px", "fontWeight": "600" }],
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "label-sm": ["11px", { "lineHeight": "14px", "fontWeight": "600" }],
                        "headline-lg": ["28px", { "lineHeight": "36px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "display-lg": ["36px", { "lineHeight": "44px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "label-md": ["12px", { "lineHeight": "16px", "letterSpacing": "0.02em", "fontWeight": "500" }]
                    }
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Hanken Grotesk', sans-serif; background-color: #f8f9ff; color: #0b1c30; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #bfc9c3; border-radius: 10px; }
        @@keyframes row-in { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
        .row-in { animation: row-in .15s ease-out; }
    </style>
</head>
<body class="bg-surface">
    <!-- Barra superior -->
    <header class="fixed top-0 w-full z-50 bg-surface border-b border-outline-variant shadow-sm flex justify-between items-center h-16 px-lg">
        <div class="flex items-center gap-md md:gap-xl">
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-sm shrink-0">
                <div class="w-9 h-9 rounded-lg bg-primary flex items-center justify-center overflow-hidden">
                    <span class="material-symbols-outlined text-white text-[20px]">storefront</span>
                </div>
                <span class="font-headline-md text-headline-md font-bold text-primary">ERP XYM</span>
            </a>
        </div>
        <div class="flex items-center gap-md">
            <a class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors text-on-surface-variant"
               asp-controller="Configuracao" asp-action="Index" title="Configurações">
                <span class="material-symbols-outlined">settings</span>
            </a>
            <div class="h-8 w-[1px] bg-outline-variant mx-sm"></div>
            <div class="flex items-center gap-sm">
                <div class="text-right hidden sm:block">
                    <p class="font-label-md text-label-md font-semibold text-on-surface">@nomeLoja</p>
                    <p class="font-label-sm text-label-sm text-outline">Administrador</p>
                </div>
                <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold overflow-hidden border-2 border-primary-fixed">
                    @if (!string.IsNullOrEmpty(logo))
                    {
                        <img src="@logo" alt="Logo" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span>@inicial</span>
                    }
                </div>
            </div>
        </div>
    </header>

    <main class="pt-24 pl-lg pr-16 pb-xl max-w-[1440px] mx-auto">

        <div id="toast" class="hidden mb-md bg-secondary-container text-on-secondary-container px-md py-sm rounded-lg font-label-md text-label-md flex items-center gap-xs w-fit">
            <span id="toastIcon" class="material-symbols-outlined text-[18px]">check_circle</span>
            <span id="toastMsg"></span>
        </div>

        <!-- Cabeçalho da página -->
        <section class="mb-md">
            <h1 class="font-headline-lg text-headline-lg text-primary">Estoque</h1>
            <p class="font-body-md text-body-md text-on-surface-variant">Acompanhe o saldo de cada produto e registre entradas e saídas.</p>
        </section>

        <!-- Resumo compacto -->
        <section class="grid grid-cols-2 md:grid-cols-4 gap-sm mb-md">
            <div class="bg-white px-md py-sm rounded-lg border border-outline-variant shadow-sm">
                <span class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Produtos</span>
                <p id="resumoTotalProdutos" class="font-title-lg text-title-lg text-primary">0</p>
            </div>
            <div class="bg-white px-md py-sm rounded-lg border border-outline-variant shadow-sm">
                <span class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Valor em Estoque</span>
                <p id="resumoValorEstoque" class="font-title-lg text-title-lg text-primary">R$ 0,00</p>
            </div>
            <div class="bg-white px-md py-sm rounded-lg border border-outline-variant shadow-sm">
                <span class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Abaixo do Mínimo</span>
                <p id="resumoBaixo" class="font-title-lg text-title-lg text-primary">0</p>
            </div>
            <div class="bg-white px-md py-sm rounded-lg border border-outline-variant shadow-sm">
                <span class="font-label-sm text-label-sm text-outline uppercase tracking-wider">Esgotados</span>
                <p id="resumoEsgotado" class="font-title-lg text-title-lg text-primary">0</p>
            </div>
        </section>

        <!-- Barra de ferramentas -->
        <section class="bg-white rounded-t-xl border border-b-0 border-outline-variant p-sm flex flex-wrap items-center gap-sm">
            <button id="toggleFiltrosBtn" type="button" title="Filtros"
                    class="w-9 h-9 rounded-lg bg-secondary text-white flex items-center justify-center hover:bg-opacity-90 transition-colors shrink-0">
                <span class="material-symbols-outlined text-[20px]">filter_alt</span>
            </button>

            <div class="relative flex-1 min-w-[200px]">
                <input id="filtroBusca" type="text" placeholder="Pesquisar por código, descrição ou categoria..."
                       class="w-full bg-surface-container-low border-none rounded-full pl-md pr-10 py-2 font-body-md text-body-md focus:ring-2 focus:ring-secondary/30" />
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-outline text-[20px]">search</span>
            </div>

            <div class="flex items-center gap-xs shrink-0 ml-auto">
                <button id="abrirMovimentacaoBtn" type="button" title="Registrar movimentação"
                        class="w-9 h-9 rounded-lg hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
                    <span class="material-symbols-outlined text-[20px]">sync_alt</span>
                </button>
                <button id="imprimirBtn" type="button" title="Imprimir lista"
                        class="w-9 h-9 rounded-lg hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
                    <span class="material-symbols-outlined text-[20px]">print</span>
                </button>
                <button id="excluirSelecionadosBtn" type="button" title="Excluir selecionados" disabled
                        class="w-9 h-9 rounded-lg hover:bg-error-container flex items-center justify-center text-outline disabled:hover:bg-transparent disabled:opacity-40 transition-colors">
                    <span class="material-symbols-outlined text-[20px]">delete</span>
                </button>
            </div>
        </section>

        <div id="filtrosExtras" class="hidden bg-white border border-b-0 border-outline-variant px-sm py-sm flex flex-wrap gap-sm items-center">
            <select id="filtroStatus" class="bg-surface-container-low border-none rounded-lg px-md py-2 font-body-md text-body-md focus:ring-2 focus:ring-secondary/30">
                <option value="">Todos os status</option>
                <option value="ok">Em dia</option>
                <option value="baixo">Abaixo do mínimo</option>
                <option value="esgotado">Esgotado</option>
            </select>
        </div>

        <!-- Chips de filtro ativo -->
        <div id="chipsFiltro" class="hidden bg-white border border-b-0 border-outline-variant px-md py-xs flex items-center gap-sm">
            <span id="chipsFiltroTexto" class="font-label-sm text-label-sm text-on-surface-variant"></span>
            <button id="limparFiltrosBtn" type="button" class="font-label-sm text-label-sm text-secondary font-bold hover:underline">Limpar</button>
        </div>

        <!-- Tabela -->
        <section class="bg-white rounded-b-xl border border-outline-variant shadow-sm overflow-hidden">
            <div class="px-lg py-xs border-b border-outline-variant flex items-center gap-sm">
                <input id="selecionarTodosCheckbox" type="checkbox" class="w-4 h-4 accent-secondary" />
                <button id="atualizarListaBtn" type="button" title="Atualizar lista" class="w-7 h-7 rounded-full hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
                    <span class="material-symbols-outlined text-[18px]">refresh</span>
                </button>
                <span id="selecionadosInfo" class="font-label-sm text-label-sm text-outline"></span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-surface-container-low">
                        <tr>
                            <th class="w-10"></th>
                            <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider">Descrição</th>
                            <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider">Código</th>
                            <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider text-right">Preço</th>
                            <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider text-center">Estoque</th>
                            <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody id="estoqueBody"></tbody>
                </table>
            </div>
            <div id="vazioState" class="hidden p-xl text-center font-body-md text-body-md text-on-surface-variant">
                Nenhum produto encontrado para esse filtro.
            </div>
        </section>
    </main>

    <!-- Trilho de ações lateral -->
    <aside class="fixed top-16 right-0 bottom-0 w-12 border-l border-outline-variant bg-white flex flex-col items-center py-md gap-md z-40">
        <button type="button" data-acao="movimentacao" title="Registrar movimentação" class="rail-btn w-9 h-9 rounded-lg hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
            <span class="material-symbols-outlined text-[20px]">sync_alt</span>
        </button>
        <button type="button" data-acao="exportar" title="Exportar lista para planilha" class="rail-btn w-9 h-9 rounded-lg hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
            <span class="material-symbols-outlined text-[20px]">upload</span>
        </button>
        <button type="button" data-acao="sincronizarEstoque" title="Sincronizar estoque na loja virtual" class="rail-btn w-9 h-9 rounded-lg hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
            <span class="material-symbols-outlined text-[20px]">inventory_2</span>
        </button>
        <button type="button" data-acao="sincronizarPrecos" title="Sincronizar preços na loja virtual" class="rail-btn w-9 h-9 rounded-lg hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
            <span class="material-symbols-outlined text-[20px]">attach_money</span>
        </button>
        <button type="button" data-acao="categorias" title="Incluir categorias para selecionados" class="rail-btn w-9 h-9 rounded-lg hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
            <span class="material-symbols-outlined text-[20px]">account_tree</span>
        </button>
        <button type="button" data-acao="etiquetas" title="Imprimir etiquetas selecionadas" class="rail-btn w-9 h-9 rounded-lg hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant transition-colors">
            <span class="material-symbols-outlined text-[20px]">description</span>
        </button>
    </aside>

    <!-- Painel de ações (expande a partir do trilho) -->
    <div id="painelAcoes" class="hidden fixed top-16 right-12 bottom-0 w-[280px] border-l border-outline-variant bg-white shadow-lg z-40 flex flex-col overflow-y-auto custom-scrollbar">
        <div class="p-md">
            <button id="painelIncluirCadastro" type="button" class="w-full bg-secondary text-white rounded-full py-sm font-label-md text-label-md font-bold hover:bg-opacity-90 transition-all flex items-center justify-center gap-xs">
                <span class="material-symbols-outlined text-[18px]">add</span>
                Incluir cadastro
            </button>
        </div>
        <nav class="flex flex-col">
            <button type="button" data-acao="movimentacao" class="painel-acao flex items-center gap-sm px-md py-sm border-t border-outline-variant text-left hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-[18px] text-outline">sync_alt</span>
                <span class="font-body-md text-body-md text-on-surface-variant">Registrar movimentação</span>
            </button>
            <button type="button" data-acao="exportar" class="painel-acao flex items-center gap-sm px-md py-sm border-t border-outline-variant text-left hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-[18px] text-outline">upload</span>
                <span class="font-body-md text-body-md text-on-surface-variant">Exportar produtos para planilha</span>
            </button>
            <button type="button" data-acao="sincronizarEstoque" class="painel-acao flex items-center gap-sm px-md py-sm border-t border-outline-variant text-left hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-[18px] text-outline">inventory_2</span>
                <span class="font-body-md text-body-md text-on-surface-variant">Sincronizar estoque na loja virtual</span>
            </button>
            <button type="button" data-acao="sincronizarPrecos" class="painel-acao flex items-center gap-sm px-md py-sm border-t border-outline-variant text-left hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-[18px] text-outline">attach_money</span>
                <span class="font-body-md text-body-md text-on-surface-variant">Sincronizar preços na loja virtual</span>
            </button>
            <button type="button" data-acao="categorias" class="painel-acao flex items-center gap-sm px-md py-sm border-t border-outline-variant text-left hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-[18px] text-outline">account_tree</span>
                <span class="font-body-md text-body-md text-on-surface-variant">Incluir categorias para selecionados</span>
            </button>
            <button type="button" data-acao="etiquetas" class="painel-acao flex items-center gap-sm px-md py-sm border-t border-b border-outline-variant text-left hover:bg-surface-container-low transition-colors">
                <span class="material-symbols-outlined text-[18px] text-outline">description</span>
                <span class="font-body-md text-body-md text-on-surface-variant">Imprimir etiquetas selecionadas</span>
            </button>
        </nav>

        <button id="maisAcoesToggle" type="button" class="flex items-center gap-xs px-md py-sm font-label-md text-label-md font-bold text-secondary">
            <span id="maisAcoesIcone" class="material-symbols-outlined text-[18px]">remove</span>
            Mais ações
        </button>
        <div id="maisAcoesConteudo" class="px-md pb-md flex flex-col gap-sm">
            <div>
                <p class="font-label-sm text-label-sm text-outline uppercase tracking-wider mb-xs">Planilhas</p>
                <button type="button" data-acao="exportarDados" class="painel-acao block w-full text-left py-xs font-body-md text-body-md text-on-surface hover:text-secondary transition-colors">Exportar dados para planilha</button>
                <button type="button" data-acao="exportarEstrutura" class="painel-acao block w-full text-left py-xs font-body-md text-body-md text-on-surface hover:text-secondary transition-colors">Exportar dados de estrutura para planilha</button>
            </div>
            <div>
                <p class="font-label-sm text-label-sm text-outline uppercase tracking-wider mb-xs">Edição</p>
                <span class="block w-full text-left py-xs font-body-md text-body-md text-outline cursor-not-allowed" title="Em breve">Incluir tags para selecionados</span>
            </div>
        </div>

        <button id="fecharPainelBtn" type="button" class="mt-auto p-sm flex items-center justify-center text-on-surface-variant hover:bg-surface-container-low transition-colors">
            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
        </button>
    </div>

    <!-- Modal: registrar movimentação -->
    <div id="modalMovimentacao" class="hidden fixed inset-0 z-[60] bg-[#0b1c30]/40 flex items-center justify-center p-md">
        <div class="bg-white rounded-xl shadow-lg w-full max-w-[440px] p-lg">
            <div class="flex justify-between items-center mb-md">
                <h2 class="font-title-lg text-title-lg text-primary">Registrar Movimentação</h2>
                <button id="fecharMovimentacaoBtn" type="button" class="w-8 h-8 rounded-full hover:bg-surface-container-low flex items-center justify-center text-on-surface-variant">
                    <span class="material-symbols-outlined text-[20px]">close</span>
                </button>
            </div>

            <div class="flex flex-col gap-md">
                <div>
                    <label class="font-label-md text-label-md text-on-surface-variant" for="movProdutoSelect">Produto</label>
                    <select id="movProdutoSelect" class="w-full mt-xs bg-surface-container-low border-none rounded-lg px-md py-2 font-body-md text-body-md focus:ring-2 focus:ring-secondary/30"></select>
                </div>

                <div>
                    <span class="font-label-md text-label-md text-on-surface-variant">Tipo</span>
                    <div class="mt-xs grid grid-cols-2 gap-sm">
                        <label class="mov-tipo-opcao flex items-center justify-center gap-xs border border-outline-variant rounded-lg py-sm cursor-pointer transition-colors" data-tipo="entrada">
                            <input type="radio" name="movTipo" value="entrada" class="accent-secondary" checked />
                            <span class="material-symbols-outlined text-[18px] text-secondary">arrow_downward</span>
                            <span class="font-label-md text-label-md text-on-surface">Entrada</span>
                        </label>
                        <label class="mov-tipo-opcao flex items-center justify-center gap-xs border border-outline-variant rounded-lg py-sm cursor-pointer transition-colors" data-tipo="saida">
                            <input type="radio" name="movTipo" value="saida" class="accent-error" />
                            <span class="material-symbols-outlined text-[18px] text-error">arrow_upward</span>
                            <span class="font-label-md text-label-md text-on-surface">Saída</span>
                        </label>
                    </div>
                </div>

                <div>
                    <label class="font-label-md text-label-md text-on-surface-variant">Quantidade</label>
                    <div class="mt-xs inline-flex items-center gap-sm bg-surface-container-low rounded-lg px-sm py-xs">
                        <button type="button" id="movQtdMenos" class="w-7 h-7 rounded-full hover:bg-white flex items-center justify-center text-on-surface-variant font-bold leading-none transition-colors">−</button>
                        <span id="movQtdValor" class="w-8 text-center font-title-lg text-title-lg font-bold text-primary">1</span>
                        <button type="button" id="movQtdMais" class="w-7 h-7 rounded-full hover:bg-white flex items-center justify-center text-on-surface-variant font-bold leading-none transition-colors">+</button>
                    </div>
                </div>

                <div>
                    <label class="font-label-md text-label-md text-on-surface-variant" for="movMotivo">Motivo (opcional)</label>
                    <input id="movMotivo" type="text" placeholder="Ex: compra de fornecedor, avaria, ajuste de contagem..."
                           class="w-full mt-xs bg-surface-container-low border-none rounded-lg px-md py-2 font-body-md text-body-md focus:ring-2 focus:ring-secondary/30" />
                </div>

                <p id="movSaldoInfo" class="font-body-md text-body-md text-on-surface-variant"></p>

                <button id="confirmarMovimentacaoBtn" type="button" class="w-full py-md rounded-lg font-title-lg text-title-lg bg-primary text-white hover:bg-opacity-90 transition-all flex items-center justify-center gap-xs">
                    Confirmar
                    <span class="material-symbols-outlined">check_circle</span>
                </button>
            </div>
        </div>
    </div>

    <script>
        const PRODUTOS_ESTOQUE = @Html.Raw(Json.Serialize(Model.Produtos));
    </script>
    <script src="~/js/estoque.js" asp-append-version="true"></script>
</body>
