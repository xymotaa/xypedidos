<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @ViewData["NomeLoja"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="app-navbar">
        <a class="brand" asp-controller="Home" asp-action="Index">
            <span class="logo-placeholder">
                @if (!string.IsNullOrEmpty(ViewData["LogoLoja"] as string))
                {
                    <img src="@ViewData["LogoLoja"]" alt="Logo" />
                }
                else
                {
                    <span>@(((string)(ViewData["NomeLoja"] ?? "L"))[0])</span>
                }
            </span>
            <span class="store-name">@ViewData["NomeLoja"]</span>
        </a>
        <div class="app-navbar-actions">
            <a class="nav-icon-btn" asp-controller="Configuracao" asp-action="Index" title="Configurações" aria-label="Configurações">
                <span aria-hidden="true">⚙️</span>
            </a>
        </div>
    </nav>

    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
