@model ListasCompras.Models.CaixaIndexViewModel
@{
    Layout = null;
    ViewData["Title"] = "Caixa";

    var nomeLoja = ViewData["NomeLoja"] as string ?? "Minha Loja";
    var logo = ViewData["LogoLoja"] as string;
    var inicial = string.IsNullOrWhiteSpace(nomeLoja) ? "L" : nomeLoja.Trim()[0].ToString().ToUpper();
}
<!DOCTYPE html>
<html class="light" lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@nomeLoja — @ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-tertiary-container": "#93baa7", "outline-variant": "#bfc9c3",
                        "on-tertiary-fixed-variant": "#294e3f", "surface": "#f8f9ff",
                        "inverse-on-surface": "#eaf1ff", "outline": "#707974", "on-primary": "#ffffff",
                        "secondary": "#006c49", "error-container": "#ffdad6", "primary-fixed-dim": "#95d3ba",
                        "on-secondary": "#ffffff", "inverse-primary": "#95d3ba", "primary": "#003527",
                        "on-error-container": "#93000a", "on-tertiary-fixed": "#002115", "primary-fixed": "#b0f0d6",
                        "on-surface": "#0b1c30", "tertiary-fixed": "#c3ecd7", "on-primary-container": "#80bea6",
                        "surface-container-highest": "#d3e4fe", "on-primary-fixed-variant": "#0b513d",
                        "on-error": "#ffffff", "surface-container-lowest": "#ffffff", "surface-container": "#e5eeff",
                        "secondary-fixed": "#6ffbbe", "surface-container-low": "#eff4ff", "surface-tint": "#2b6954",
                        "background": "#f8f9ff", "on-primary-fixed": "#002117", "primary-container": "#064e3b",
                        "on-background": "#0b1c30", "tertiary-container": "#274b3c", "error": "#ba1a1a",
                        "surface-bright": "#f8f9ff", "inverse-surface": "#213145", "tertiary": "#0e3427",
                        "surface-dim": "#cbdbf5", "on-secondary-fixed-variant": "#005236", "tertiary-fixed-dim": "#a8cfbc",
                        "secondary-fixed-dim": "#4edea3", "surface-container-high": "#dce9ff",
                        "on-secondary-container": "#00714d", "secondary-container": "#6cf8bb",
                        "surface-variant": "#d3e4fe", "on-surface-variant": "#404944", "on-tertiary": "#ffffff",
                        "on-secondary-fixed": "#002113"
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                    spacing: { "container-margin": "24px", "lg": "24px", "base": "4px", "gutter": "16px", "sm": "8px", "xs": "4px", "md": "16px", "xl": "32px" },
                    fontFamily: {
                        "body-md": ["Hanken Grotesk"], "headline-md": ["Hanken Grotesk"], "title-lg": ["Hanken Grotesk"],
                        "body-lg": ["Hanken Grotesk"], "label-sm": ["Hanken Grotesk"], "headline-lg": ["Hanken Grotesk"],
                        "display-lg": ["Hanken Grotesk"], "label-md": ["Hanken Grotesk"]
                    },
                    fontSize: {
                        "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "headline-md": ["22px", { "lineHeight": "30px", "fontWeight": "600" }],
                        "title-lg": ["18px", { "lineHeight": "24px", "fontWeight": "600" }],
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "label-sm": ["11px", { "lineHeight": "14px", "fontWeight": "600" }],
                        "headline-lg": ["28px", { "lineHeight": "36px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "display-lg": ["36px", { "lineHeight": "44px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "label-md": ["12px", { "lineHeight": "16px", "letterSpacing": "0.02em", "fontWeight": "500" }]
                    }
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Hanken Grotesk', sans-serif; background-color: #f8f9ff; color: #0b1c30; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .qtd-input::-webkit-inner-spin-button, .qtd-input::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
        .qtd-input { -moz-appearance: textfield; }
        @@keyframes row-in { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
        .row-in { animation: row-in .15s ease-out; }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #bfc9c3; border-radius: 10px; }
    </style>
</head>
<body class="bg-surface">
    <!-- Barra superior -->
    <header class="fixed top-0 w-full z-50 bg-surface border-b border-outline-variant shadow-sm flex justify-between items-center h-16 px-lg">
        <div class="flex items-center gap-md md:gap-xl">
            <a asp-controller="Home" asp-action="Index" class="flex items-center gap-sm shrink-0">
                <div class="w-9 h-9 rounded-lg bg-primary flex items-center justify-center overflow-hidden">
                    <span class="material-symbols-outlined text-white text-[20px]">storefront</span>
                </div>
                <span class="font-headline-md text-headline-md font-bold text-primary">ERP XYM</span>
            </a>
        </div>
        <div class="flex items-center gap-md">
            <a class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors text-on-surface-variant"
               asp-controller="Configuracao" asp-action="Index" title="Configurações">
                <span class="material-symbols-outlined">settings</span>
            </a>
            <div class="h-8 w-[1px] bg-outline-variant mx-sm"></div>
            <div class="flex items-center gap-sm">
                <div class="text-right hidden sm:block">
                    <p class="font-label-md text-label-md font-semibold text-on-surface">@nomeLoja</p>
                    <p class="font-label-sm text-label-sm text-outline">Administrador</p>
                </div>
                <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold overflow-hidden border-2 border-primary-fixed">
                    @if (!string.IsNullOrEmpty(logo))
                    {
                        <img src="@logo" alt="Logo" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span>@inicial</span>
                    }
                </div>
            </div>
        </div>
    </header>

    <!-- Frente de caixa -->
    <div class="pt-16 h-screen flex flex-col overflow-hidden">
        <div class="flex-1 flex overflow-hidden">

            <!-- Coluna principal: busca + itens -->
            <div class="flex-1 flex flex-col p-lg gap-md overflow-hidden min-w-0">

                <div id="toast" class="hidden shrink-0 bg-secondary-container text-on-secondary-container px-md py-sm rounded-lg font-label-md text-label-md flex items-center gap-xs">
                    <span class="material-symbols-outlined text-[18px]">check_circle</span>
                    <span id="toastMsg">Venda finalizada.</span>
                </div>

                <form id="buscaForm" class="shrink-0 flex gap-sm" autocomplete="off">
                    <div class="relative flex-1">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
                        <input id="buscaInput" list="produtosDatalist"
                               class="w-full bg-surface-container-low border-none rounded-lg pl-10 pr-4 py-3 font-body-md text-body-md focus:ring-2 focus:ring-secondary/30"
                               placeholder="Escanear código de barras ou buscar produto por nome (F2)" type="text" />
                        <datalist id="produtosDatalist">
                            @foreach (var p in Model.Produtos)
                            {
                                <option value="@p.Nome"></option>
                            }
                        </datalist>
                    </div>
                    <button type="submit" class="bg-primary text-white px-lg rounded-lg font-label-md text-label-md hover:bg-opacity-90 transition-all flex items-center gap-xs shrink-0">
                        <span class="material-symbols-outlined text-[18px]">add</span>
                        Adicionar
                    </button>
                </form>

                <div class="flex-1 bg-white rounded-xl border border-outline-variant shadow-sm overflow-y-auto custom-scrollbar">
                    <table class="w-full text-left border-collapse">
                        <thead class="sticky top-0 bg-surface-container-low z-10">
                            <tr>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider">Item</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider">Código</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider">Produto</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider text-center">Qtd</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider text-right">Vlr. Unit.</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider text-right">Subtotal</th>
                                <th class="px-md py-sm font-label-sm text-label-sm text-outline uppercase tracking-wider text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody id="itensBody"></tbody>
                    </table>
                    <div id="vazioState" class="p-xl text-center font-body-md text-body-md text-on-surface-variant">
                        Nenhum item na venda. Escaneie ou busque um produto para começar.
                    </div>
                </div>
            </div>

            <!-- Coluna lateral: resumo e pagamento -->
            <aside class="w-[360px] shrink-0 border-l border-outline-variant bg-white flex flex-col overflow-y-auto custom-scrollbar">
                <div class="p-lg border-b border-outline-variant">
                    <h2 class="font-title-lg text-title-lg text-primary mb-md">Resumo da Venda</h2>
                    <div class="flex justify-between items-center mb-xs">
                        <span id="subtotalLabel" class="font-body-md text-body-md text-on-surface-variant">Subtotal (0 itens)</span>
                        <span id="subtotalValor" class="font-body-md text-body-md text-on-surface">R$ 0,00</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="font-body-md text-body-md text-on-surface-variant">Descontos</span>
                        <span class="font-body-md text-body-md text-error">- R$ 0,00</span>
                    </div>
                    <div class="h-[1px] bg-outline-variant my-md"></div>
                    <div class="flex justify-between items-center">
                        <span class="font-title-lg text-title-lg text-on-surface">Total</span>
                        <span id="totalValor" class="font-display-lg text-display-lg text-primary">R$ 0,00</span>
                    </div>
                </div>

                <div class="p-lg border-b border-outline-variant">
                    <h3 class="font-title-lg text-title-lg text-primary mb-md">Forma de Pagamento</h3>
                    <div class="flex flex-col gap-sm" id="formasPagamento">
                        <label class="pagamento-opcao flex items-center gap-sm border border-outline-variant rounded-lg px-md py-sm cursor-pointer transition-colors" data-metodo="dinheiro">
                            <input type="radio" name="metodo" value="dinheiro" class="accent-secondary" checked />
                            <span class="material-symbols-outlined text-on-surface-variant">payments</span>
                            <span class="font-label-md text-label-md text-on-surface">Dinheiro</span>
                        </label>
                        <label class="pagamento-opcao flex items-center gap-sm border border-outline-variant rounded-lg px-md py-sm cursor-pointer transition-colors" data-metodo="cartao">
                            <input type="radio" name="metodo" value="cartao" class="accent-secondary" />
                            <span class="material-symbols-outlined text-on-surface-variant">credit_card</span>
                            <span class="font-label-md text-label-md text-on-surface">Cartão (Crédito/Débito)</span>
                        </label>
                        <label class="pagamento-opcao flex items-center gap-sm border border-outline-variant rounded-lg px-md py-sm cursor-pointer transition-colors" data-metodo="pix">
                            <input type="radio" name="metodo" value="pix" class="accent-secondary" />
                            <span class="material-symbols-outlined text-on-surface-variant">qr_code_2</span>
                            <span class="font-label-md text-label-md text-on-surface">PIX</span>
                        </label>
                    </div>

                    <div id="painelDinheiro" class="mt-md flex flex-col gap-sm">
                        <label class="font-label-md text-label-md text-on-surface-variant" for="valorRecebido">Valor Recebido</label>
                        <div class="relative">
                            <span class="absolute left-3 top-1/2 -translate-y-1/2 font-body-md text-body-md text-outline">R$</span>
                            <input id="valorRecebido" type="number" min="0" step="0.01" placeholder="0,00"
                                   class="w-full bg-surface-container-low border-none rounded-lg pl-10 pr-4 py-2 font-body-md text-body-md focus:ring-2 focus:ring-secondary/30" />
                        </div>
                        <div class="flex justify-between items-center bg-surface-container-low rounded-lg px-md py-sm">
                            <span class="font-label-md text-label-md text-on-surface-variant">Troco</span>
                            <span id="trocoValor" class="font-title-lg text-title-lg text-primary">R$ 0,00</span>
                        </div>
                    </div>
                </div>

                <div class="flex-1"></div>

                <div class="p-lg">
                    <button id="finalizarBtn" disabled
                            class="w-full py-md rounded-lg font-title-lg text-title-lg flex items-center justify-center gap-xs transition-all bg-outline-variant text-outline cursor-not-allowed">
                        Finalizar Venda
                        <span class="material-symbols-outlined">check_circle</span>
                    </button>
                </div>
            </aside>
        </div>
    </div>

    <script>
        const PRODUTOS = @Html.Raw(Json.Serialize(Model.Produtos));
    </script>
    <script src="~/js/caixa.js" asp-append-version="true"></script>
</body>
</html>
