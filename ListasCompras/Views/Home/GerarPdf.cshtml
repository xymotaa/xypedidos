@model ListasCompras.Models.ListaCompra
@{
    Layout = null;
    var nomeLoja = ViewData["NomeLoja"] as string;
    var logo = ViewData["LogoLoja"] as string;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lista de Reposição - @nomeLoja</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/print.css" asp-append-version="true" />
</head>
<body>
    <div class="report-topbar no-print">
        <span class="trilha">
            <a asp-controller="Home" asp-action="Index">Dashboard</a> /
            <span class="atual">Relatório de Reposição</span>
        </span>
        <button type="button" class="btn-app btn-app-primary" onclick="window.print()">🖨️ Imprimir / Baixar PDF</button>
    </div>

    <div class="report-shell">
        <div class="report-card">
            <div class="pdf-header">
                <div class="pdf-header-brand">
                    <div class="logo-placeholder">
                        @if (!string.IsNullOrEmpty(logo))
                        {
                            <img src="@logo" alt="Logo" />
                        }
                    </div>
                    <div>
                        <div class="nome-loja">@nomeLoja</div>
                        <div class="subtitulo">Lista de reposição de estoque</div>
                    </div>
                </div>
                <div class="pdf-header-meta">
                    <div class="rotulo">LISTA DE REPOSIÇÃO</div>
                    <div class="data">Emitido em @DateTime.Now.ToString("dd/MM/yyyy")</div>
                </div>
            </div>

            <div class="pdf-info-bar">
                <div class="pdf-info-item">
                    <span class="pdf-info-label">Nº da lista</span>
                    <span class="pdf-info-valor">#@Model.Id</span>
                </div>
                <div class="pdf-info-item">
                    <span class="pdf-info-label">Data de criação</span>
                    <span class="pdf-info-valor">@Model.DataCriacao.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="pdf-info-item">
                    <span class="pdf-info-label">Status</span>
                    <span class="pdf-info-valor">@Model.Status</span>
                </div>
            </div>

            <table class="pdf-table">
                <thead>
                    <tr>
                        <th>Produto</th>
                        <th>Modelo</th>
                        <th>Qtd</th>
                        <th>Observação</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var grupo in Model.Itens.GroupBy(i => i.Produto.Categoria.Nome).OrderBy(g => g.Key))
                    {
                        <tr class="pdf-group-spacer"><td colspan="4"></td></tr>
                        <tr class="pdf-group-header">
                            <td colspan="4">@grupo.Key</td>
                        </tr>
                        @foreach (var item in grupo)
                        {
                            <tr>
                                <td>@item.Produto.Nome</td>
                                <td>@(item.ModeloCelular != null ? $"{item.ModeloCelular.MarcaCelular.Nome} {item.ModeloCelular.Nome}" : "-")</td>
                                <td>@item.Quantidade</td>
                                <td>@(string.IsNullOrEmpty(item.Observacao) ? "-" : item.Observacao)</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>

            <div class="pdf-footer">
                <span>Total de itens</span>
                <strong>@Model.Itens.Count</strong>
            </div>
        </div>
    </div>
</body>
</html>
