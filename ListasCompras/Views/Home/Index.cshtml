@{
    Layout = null;
    ViewData["Title"] = "Painel";

    var nomeLoja = ViewData["NomeLoja"] as string ?? "Minha Loja";
    var logo = ViewData["LogoLoja"] as string;
    var inicial = string.IsNullOrWhiteSpace(nomeLoja) ? "L" : nomeLoja.Trim()[0].ToString().ToUpper();

    var hora = DateTime.Now.Hour;
    var saudacao = hora < 12 ? "Bom dia" : hora < 18 ? "Boa tarde" : "Boa noite";

    // Itens da barra lateral. "Painel" é a tela atual (ativa).
    var navItens = new[]
    {
        new { Nome = "Painel",           Icone = "dashboard",      Controller = "Home",        Ativo = true  },
        new { Nome = "Lista de Compra",  Icone = "shopping_cart",  Controller = "ListaCompra", Ativo = false },
        new { Nome = "Caixa",            Icone = "point_of_sale",  Controller = "Caixa",       Ativo = false },
        new { Nome = "Estoque",          Icone = "inventory_2",    Controller = "Estoque",     Ativo = false },
        new { Nome = "Orçamento",        Icone = "request_quote",  Controller = "Orcamento",   Ativo = false },
        new { Nome = "Dashboards",       Icone = "analytics",      Controller = "Dashboards",  Ativo = false },
    };
}
<!DOCTYPE html>
<html class="light" lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@nomeLoja — Painel</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-tertiary-container": "#93baa7", "outline-variant": "#bfc9c3",
                        "on-tertiary-fixed-variant": "#294e3f", "surface": "#f8f9ff",
                        "inverse-on-surface": "#eaf1ff", "outline": "#707974", "on-primary": "#ffffff",
                        "secondary": "#006c49", "error-container": "#ffdad6", "primary-fixed-dim": "#95d3ba",
                        "on-secondary": "#ffffff", "inverse-primary": "#95d3ba", "primary": "#003527",
                        "on-error-container": "#93000a", "on-tertiary-fixed": "#002115", "primary-fixed": "#b0f0d6",
                        "on-surface": "#0b1c30", "tertiary-fixed": "#c3ecd7", "on-primary-container": "#80bea6",
                        "surface-container-highest": "#d3e4fe", "on-primary-fixed-variant": "#0b513d",
                        "on-error": "#ffffff", "surface-container-lowest": "#ffffff", "surface-container": "#e5eeff",
                        "secondary-fixed": "#6ffbbe", "surface-container-low": "#eff4ff", "surface-tint": "#2b6954",
                        "background": "#f8f9ff", "on-primary-fixed": "#002117", "primary-container": "#064e3b",
                        "on-background": "#0b1c30", "tertiary-container": "#274b3c", "error": "#ba1a1a",
                        "surface-bright": "#f8f9ff", "inverse-surface": "#213145", "tertiary": "#0e3427",
                        "surface-dim": "#cbdbf5", "on-secondary-fixed-variant": "#005236", "tertiary-fixed-dim": "#a8cfbc",
                        "secondary-fixed-dim": "#4edea3", "surface-container-high": "#dce9ff",
                        "on-secondary-container": "#00714d", "secondary-container": "#6cf8bb",
                        "surface-variant": "#d3e4fe", "on-surface-variant": "#404944", "on-tertiary": "#ffffff",
                        "on-secondary-fixed": "#002113"
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                    spacing: { "container-margin": "24px", "lg": "24px", "base": "4px", "gutter": "16px", "sm": "8px", "xs": "4px", "md": "16px", "xl": "32px" },
                    fontFamily: {
                        "body-md": ["Hanken Grotesk"], "headline-md": ["Hanken Grotesk"], "title-lg": ["Hanken Grotesk"],
                        "body-lg": ["Hanken Grotesk"], "label-sm": ["Hanken Grotesk"], "headline-lg": ["Hanken Grotesk"],
                        "display-lg": ["Hanken Grotesk"], "label-md": ["Hanken Grotesk"]
                    },
                    fontSize: {
                        "body-md": ["14px", { "lineHeight": "20px", "fontWeight": "400" }],
                        "headline-md": ["22px", { "lineHeight": "30px", "fontWeight": "600" }],
                        "title-lg": ["18px", { "lineHeight": "24px", "fontWeight": "600" }],
                        "body-lg": ["16px", { "lineHeight": "24px", "fontWeight": "400" }],
                        "label-sm": ["11px", { "lineHeight": "14px", "fontWeight": "600" }],
                        "headline-lg": ["28px", { "lineHeight": "36px", "letterSpacing": "-0.01em", "fontWeight": "600" }],
                        "display-lg": ["36px", { "lineHeight": "44px", "letterSpacing": "-0.02em", "fontWeight": "700" }],
                        "label-md": ["12px", { "lineHeight": "16px", "letterSpacing": "0.02em", "fontWeight": "500" }]
                    }
                },
            },
        }
    </script>
    <style>
        body { font-family: 'Hanken Grotesk', sans-serif; background-color: #f8f9ff; color: #0b1c30; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .glass-card { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(12px); border: 1px solid rgba(226, 232, 240, 0.8); }
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #bfc9c3; border-radius: 10px; }

        /* Recolher / abrir a barra lateral */
        #sidebar { transition: transform 0.2s ease-in-out; }
        #mainContent, #topbarTitle { transition: margin-left 0.2s ease-in-out; }
        @@media (min-width: 768px) {
            body.sidebar-collapsed #sidebar { transform: translateX(-100%); }
            body.sidebar-collapsed #mainContent,
            body.sidebar-collapsed #topbarTitle { margin-left: 0; }
        }
    </style>
</head>
<body class="bg-surface custom-scrollbar">
    <!-- Barra lateral -->
    <aside id="sidebar" class="fixed left-0 top-0 h-full w-[260px] z-40 bg-surface border-r border-outline-variant flex-col pt-20 pb-lg hidden md:flex">
        <div class="px-lg mb-xl">
            <a href="@Url.Action("Index", "Home")" class="flex items-center gap-md">
                <div class="w-10 h-10 rounded-lg bg-primary flex items-center justify-center overflow-hidden shrink-0">
                    @if (!string.IsNullOrEmpty(logo))
                    {
                        <img src="@logo" alt="Logo" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-white">storefront</span>
                    }
                </div>
                <div>
                    <h1 class="font-title-lg text-title-lg font-bold text-primary leading-tight">@nomeLoja</h1>
                    <p class="font-label-md text-label-md text-on-surface-variant">Painel administrativo</p>
                </div>
            </a>
        </div>
        <nav class="flex-1 px-md space-y-xs">
            @foreach (var item in navItens)
            {
                if (item.Ativo)
                {
                    <a class="flex items-center gap-md px-md py-sm rounded-lg text-secondary font-bold border-l-4 border-secondary bg-surface-container-low transition-all duration-200"
                       asp-controller="@item.Controller" asp-action="Index">
                        <span class="material-symbols-outlined">@item.Icone</span>
                        <span class="font-label-md text-label-md">@item.Nome</span>
                    </a>
                }
                else
                {
                    <a class="flex items-center gap-md px-md py-sm rounded-lg text-on-surface-variant hover:bg-surface-container-low transition-all duration-200"
                       asp-controller="@item.Controller" asp-action="Index">
                        <span class="material-symbols-outlined">@item.Icone</span>
                        <span class="font-label-md text-label-md">@item.Nome</span>
                    </a>
                }
            }
        </nav>
        <div class="mt-auto px-md space-y-xs pt-lg border-t border-outline-variant">
            <a class="flex items-center gap-md px-md py-sm rounded-lg text-on-surface-variant hover:bg-surface-container-low transition-all duration-200"
               asp-controller="Configuracao" asp-action="Index">
                <span class="material-symbols-outlined">settings</span>
                <span class="font-label-md text-label-md">Configurações</span>
            </a>
        </div>
    </aside>

    <!-- Barra superior -->
    <header class="fixed top-0 w-full z-50 bg-surface border-b border-outline-variant shadow-sm flex justify-between items-center h-16 px-lg">
        <div class="flex items-center gap-md md:gap-xl">
            <button type="button" onclick="toggleSidebar()" aria-label="Recolher ou abrir o menu"
                    class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant bg-surface-container-low text-on-surface-variant hover:bg-surface-container-high hover:text-primary transition-colors shrink-0">
                <span class="material-symbols-outlined">menu</span>
            </button>
            <div id="topbarTitle" class="md:ml-[260px] block">
                <span class="font-headline-md text-headline-md font-bold text-primary">Painel</span>
            </div>
            <div class="relative w-96 hidden lg:block">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
                <input class="w-full bg-surface-container-low border-none rounded-full pl-10 pr-4 py-2 font-body-md text-body-md focus:ring-2 focus:ring-secondary/20"
                       placeholder="Pesquisar…" type="text" disabled />
            </div>
        </div>
        <div class="flex items-center gap-md">
            <a class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors text-on-surface-variant"
               asp-controller="Configuracao" asp-action="Index" title="Configurações">
                <span class="material-symbols-outlined">settings</span>
            </a>
            <div class="h-8 w-[1px] bg-outline-variant mx-sm"></div>
            <div class="flex items-center gap-sm">
                <div class="text-right hidden sm:block">
                    <p class="font-label-md text-label-md font-semibold text-on-surface">@nomeLoja</p>
                    <p class="font-label-sm text-label-sm text-outline">Administrador</p>
                </div>
                <div class="w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold overflow-hidden border-2 border-primary-fixed">
                    @if (!string.IsNullOrEmpty(logo))
                    {
                        <img src="@logo" alt="Logo" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <span>@inicial</span>
                    }
                </div>
            </div>
        </div>
    </header>

    <!-- Conteúdo -->
    <main id="mainContent" class="md:ml-[260px] pt-24 px-lg pb-xl max-w-[1440px]">
        <!-- Boas-vindas -->
        <section class="mb-xl">
            <div class="flex flex-wrap items-center gap-md mb-xs">
                <h2 class="font-headline-lg text-headline-lg text-primary">@saudacao, Administrador</h2>
                <span class="bg-surface-container text-on-surface-variant px-sm py-xs rounded-full font-label-sm text-label-sm">Prévia · dados de exemplo</span>
            </div>
            <p class="font-body-lg text-body-lg text-on-surface-variant">Escolha um módulo para começar ou acompanhe o resumo da @nomeLoja.</p>
        </section>

        <!-- Acesso rápido aos módulos -->
        <section class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-gutter mb-xl">
            <a asp-controller="ListaCompra" asp-action="Index" class="glass-card p-md rounded-xl flex flex-col items-center justify-center gap-sm hover:border-secondary transition-all group">
                <div class="w-12 h-12 rounded-full bg-tertiary-fixed flex items-center justify-center text-tertiary group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[28px]">shopping_cart</span>
                </div>
                <span class="font-title-lg text-title-lg text-primary text-center">Lista de compra</span>
            </a>
            <a asp-controller="Caixa" asp-action="Index" class="glass-card p-md rounded-xl flex flex-col items-center justify-center gap-sm hover:border-secondary transition-all group">
                <div class="w-12 h-12 rounded-full bg-secondary-container flex items-center justify-center text-secondary group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[28px]">point_of_sale</span>
                </div>
                <span class="font-title-lg text-title-lg text-primary text-center">Caixa</span>
            </a>
            <a asp-controller="Estoque" asp-action="Index" class="glass-card p-md rounded-xl flex flex-col items-center justify-center gap-sm hover:border-secondary transition-all group">
                <div class="w-12 h-12 rounded-full bg-primary-fixed flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[28px]">inventory_2</span>
                </div>
                <span class="font-title-lg text-title-lg text-primary text-center">Estoque</span>
            </a>
            <a asp-controller="Orcamento" asp-action="Index" class="glass-card p-md rounded-xl flex flex-col items-center justify-center gap-sm hover:border-secondary transition-all group">
                <div class="w-12 h-12 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[28px]">request_quote</span>
                </div>
                <span class="font-title-lg text-title-lg text-primary text-center">Orçamento</span>
            </a>
            <a asp-controller="Dashboards" asp-action="Index" class="glass-card p-md rounded-xl flex flex-col items-center justify-center gap-sm hover:border-secondary transition-all group col-span-2 md:col-span-1">
                <div class="w-12 h-12 rounded-full bg-secondary flex items-center justify-center text-white group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[28px]">analytics</span>
                </div>
                <span class="font-title-lg text-title-lg text-primary text-center">Dashboards</span>
            </a>
        </section>

        <!-- Indicadores (dados de exemplo) -->
        <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter mb-xl">
            <div class="bg-white p-lg rounded-xl border border-outline-variant shadow-sm">
                <div class="flex justify-between items-start mb-md">
                    <span class="font-label-md text-label-md text-outline uppercase tracking-wider">Vendas Hoje</span>
                    <span class="text-secondary bg-secondary-container px-2 py-1 rounded-full font-label-sm text-label-sm">+12.5%</span>
                </div>
                <h3 class="font-display-lg text-display-lg text-primary">R$ 12.450</h3>
                <p class="font-body-md text-body-md text-on-surface-variant mt-sm">24 novas transações</p>
            </div>
            <div class="bg-white p-lg rounded-xl border border-outline-variant shadow-sm">
                <div class="flex justify-between items-start mb-md">
                    <span class="font-label-md text-label-md text-outline uppercase tracking-wider">Itens em Falta</span>
                    <span class="text-error bg-error-container px-2 py-1 rounded-full font-label-sm text-label-sm">Urgente</span>
                </div>
                <h3 class="font-display-lg text-display-lg text-primary">18</h3>
                <p class="font-body-md text-body-md text-on-surface-variant mt-sm">Necessita reposição</p>
            </div>
            <div class="bg-white p-lg rounded-xl border border-outline-variant shadow-sm">
                <div class="flex justify-between items-start mb-md">
                    <span class="font-label-md text-label-md text-outline uppercase tracking-wider">Contas a Pagar</span>
                    <span class="text-on-surface-variant bg-surface-container px-2 py-1 rounded-full font-label-sm text-label-sm">7 dias</span>
                </div>
                <h3 class="font-display-lg text-display-lg text-primary">R$ 4.200</h3>
                <p class="font-body-md text-body-md text-on-surface-variant mt-sm">Vencimentos próximos</p>
            </div>
            <div class="bg-white p-lg rounded-xl border border-outline-variant shadow-sm">
                <div class="flex justify-between items-start mb-md">
                    <span class="font-label-md text-label-md text-outline uppercase tracking-wider">Novos Clientes</span>
                    <span class="text-secondary bg-secondary-container px-2 py-1 rounded-full font-label-sm text-label-sm">+8%</span>
                </div>
                <h3 class="font-display-lg text-display-lg text-primary">42</h3>
                <p class="font-body-md text-body-md text-on-surface-variant mt-sm">Este mês</p>
            </div>
        </section>

        <!-- Gráfico + atividades -->
        <section class="grid grid-cols-1 lg:grid-cols-3 gap-xl">
            <div class="lg:col-span-2 bg-white rounded-xl border border-outline-variant overflow-hidden shadow-sm flex flex-col">
                <div class="p-lg border-b border-outline-variant flex justify-between items-center">
                    <div>
                        <h4 class="font-title-lg text-title-lg text-primary">Desempenho Semanal</h4>
                        <p class="font-body-md text-body-md text-on-surface-variant">Fluxo de caixa e vendas</p>
                    </div>
                    <select class="bg-surface border-outline-variant rounded-lg font-label-md text-label-md px-md py-sm">
                        <option>Últimos 7 dias</option>
                        <option>Últimos 30 dias</option>
                    </select>
                </div>
                <div class="flex-1 p-lg relative min-h-[300px] flex items-end justify-between gap-md">
                    @{
                        var barras = new[] { ("Seg", 40, "R$2k"), ("Ter", 65, "R$3.5k"), ("Qua", 55, "R$2.8k"), ("Qui", 90, "R$5k"), ("Sex", 70, "R$3.8k"), ("Sáb", 45, "R$2.2k"), ("Dom", 80, "R$4.1k") };
                    }
                    @foreach (var (dia, altura, valor) in barras)
                    {
                        var destaque = altura >= 90;
                        <div class="flex-1 @(destaque ? "bg-primary hover:bg-secondary" : "bg-surface-container-low hover:bg-primary-fixed") rounded-t-lg relative group transition-all cursor-pointer"
                             style="height: @(altura)%">
                            <div class="absolute -top-8 left-1/2 -translate-x-1/2 opacity-0 group-hover:opacity-100 transition-opacity bg-primary text-white px-2 py-1 rounded text-xs whitespace-nowrap">@valor</div>
                        </div>
                    }
                </div>
                <div class="px-lg pb-md flex justify-between text-outline font-label-md text-label-md">
                    @foreach (var (dia, _, _) in barras)
                    {
                        <span>@dia</span>
                    }
                </div>
            </div>

            <div class="bg-white rounded-xl border border-outline-variant shadow-sm flex flex-col">
                <div class="p-lg border-b border-outline-variant">
                    <h4 class="font-title-lg text-title-lg text-primary">Atividades Recentes</h4>
                </div>
                <div class="flex-1 overflow-y-auto max-h-[400px] custom-scrollbar">
                    <div class="p-md space-y-md">
                        <div class="flex gap-md">
                            <div class="w-8 h-8 rounded-full bg-secondary-container flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-[18px] text-secondary">shopping_cart</span>
                            </div>
                            <div>
                                <p class="font-body-md text-body-md text-on-surface">Nova lista de reposição gerada</p>
                                <span class="font-label-sm text-label-sm text-outline">Há 5 minutos</span>
                            </div>
                        </div>
                        <div class="flex gap-md">
                            <div class="w-8 h-8 rounded-full bg-primary-fixed flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-[18px] text-primary">inventory_2</span>
                            </div>
                            <div>
                                <p class="font-body-md text-body-md text-on-surface">Ajuste de estoque: "Capinha Silicone"</p>
                                <span class="font-label-sm text-label-sm text-outline">Há 22 minutos</span>
                            </div>
                        </div>
                        <div class="flex gap-md">
                            <div class="w-8 h-8 rounded-full bg-tertiary-fixed flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-[18px] text-tertiary">person</span>
                            </div>
                            <div>
                                <p class="font-body-md text-body-md text-on-surface">Novo cliente cadastrado</p>
                                <span class="font-label-sm text-label-sm text-outline">Há 1 hora</span>
                            </div>
                        </div>
                        <div class="flex gap-md">
                            <div class="w-8 h-8 rounded-full bg-error-container flex items-center justify-center shrink-0">
                                <span class="material-symbols-outlined text-[18px] text-error">priority_high</span>
                            </div>
                            <div>
                                <p class="font-body-md text-body-md text-on-surface">Alerta de estoque baixo: Película</p>
                                <span class="font-label-sm text-label-sm text-outline">Há 3 horas</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="p-md border-t border-outline-variant text-center">
                    <a asp-controller="Dashboards" asp-action="Index" class="font-label-md text-label-md text-secondary font-bold hover:underline">Ver todo o histórico</a>
                </div>
            </div>
        </section>

        <!-- Tabela: últimos orçamentos (dados de exemplo) -->
        <section class="mt-xl bg-white rounded-xl border border-outline-variant shadow-sm overflow-hidden">
            <div class="p-lg flex justify-between items-center">
                <h4 class="font-title-lg text-title-lg text-primary">Últimos Orçamentos</h4>
                <a asp-controller="Orcamento" asp-action="Index" class="bg-secondary text-white px-md py-sm rounded-lg font-label-md text-label-md hover:bg-opacity-90 transition-all flex items-center gap-xs">
                    <span class="material-symbols-outlined text-[18px]">add</span>
                    Novo Orçamento
                </a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-surface-container-low border-y border-outline-variant">
                            <th class="px-lg py-md font-label-md text-label-md text-outline uppercase">ID</th>
                            <th class="px-lg py-md font-label-md text-label-md text-outline uppercase">Cliente</th>
                            <th class="px-lg py-md font-label-md text-label-md text-outline uppercase">Data</th>
                            <th class="px-lg py-md font-label-md text-label-md text-outline uppercase">Valor</th>
                            <th class="px-lg py-md font-label-md text-label-md text-outline uppercase">Status</th>
                            <th class="px-lg py-md font-label-md text-label-md text-outline uppercase">Ação</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="px-lg py-md font-body-md text-body-md">#ORC-1209</td>
                            <td class="px-lg py-md font-body-md text-body-md">Auto Oficina Central</td>
                            <td class="px-lg py-md font-body-md text-body-md">12/10/2023</td>
                            <td class="px-lg py-md font-body-md text-body-md">R$ 1.850,00</td>
                            <td class="px-lg py-md"><span class="bg-secondary-container text-secondary px-sm py-xs rounded-full font-label-sm text-label-sm">Aprovado</span></td>
                            <td class="px-lg py-md"><span class="material-symbols-outlined text-outline cursor-pointer hover:text-primary">more_horiz</span></td>
                        </tr>
